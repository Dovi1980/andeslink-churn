# .gitignore — raíz del proyecto
 
# Entorno Python
__pycache__/
*.pyc
*.pyo
.env
venv/
env/
 
# Datos — se versionan con DVC
data/raw/
data/processed/
 
# Modelos — se versionan con DVC o MLflow
models/*.pkl
models/*.joblib
 
# MLflow
mlruns/
 
# DVC cache local
.dvc/cache/
.dvc/tmp/
 
# JupyterLab
.ipynb_checkpoints/
 
# VSCode
.vscode/
 
# Docker
.docker/
 
# Sistema operativo
.DS_Store
Thumbs.db
 
# Reportes generados
reports/figures/*.png
reports/figures/*.svg